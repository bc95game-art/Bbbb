<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility service config — targeted at ir.medu.shad only.

    Targeting a specific package instead of all apps:
      • Reduces OS/security-layer suspicion on MIUI / locked-down ROMs
      • Lowers the permission-grant barrier on some devices
      • Still captures all relevant link events inside the Shad app

    If you ever need to monitor additional packages, add them comma-separated
    in android:packageNames and mirror the change in onServiceConnected().
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:packageNames="ir.medu.shad"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged|typeViewScrolled|typeViewTextChanged|typeViewClicked"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagReportViewIds|flagIncludeNotImportantViews|flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100" />
